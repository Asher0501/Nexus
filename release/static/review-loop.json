{
  "nodes": [
    {
      "id": "seed",
      "providers": [{ "type": "shell", "command": "python scripts/read_arch.py" }],
      "process_timeout_secs": 10
    },
    {
      "id": "review",
      "providers": [{
        "type": "llm",
        "command": "claude -p \"{{prompt}}\" --output-format json --verbose",
        "prompt": "Round {{metadata.run_count}}/2. Critique this architecture doc for abstraction consistency, design rationale, and logical gaps. Last fix: {{inputs.fix}}. Issues → route='again'. Done → route='stop'. Doc: {{inputs.seed}}. Output ONLY JSON with route field. Write review to review.md.",
        "routes": ["again", "stop"]
      }],
      "process_timeout_secs": 300,
      "route_policy": { "type": "max_runs", "max": 2, "then_route": "stop" }
    },
    {
      "id": "fix",
      "providers": [{
        "type": "llm",
        "command": "claude -p \"{{prompt}}\" --output-format json --verbose",
        "prompt": "Rewrite problematic sections based on review. Review: {{inputs.review}}. Original doc: {{inputs.seed}}. Output ONLY JSON with route='done'. Write fixes to fix.md.",
        "routes": ["done"]
      }],
      "process_timeout_secs": 300
    },
    {
      "id": "exit",
      "providers": [{ "type": "shell", "command": "scripts/node_ok.bat" }],
      "process_timeout_secs": 10
    }
  ],
  "edges": [
    { "from": "seed",   "to": "review", "trigger": "any", "event": "complete" },
    { "from": "review", "to": "fix",    "trigger": "any", "event": "complete", "exit_reason": "again" },
    { "from": "fix",    "to": "review", "trigger": "any", "event": "complete" },
    { "from": "review", "to": "exit",   "trigger": "any", "event": "complete", "exit_reason": "stop" }
  ],
  "dataflows": [
    { "from": "seed",   "to": "review" },
    { "from": "seed",   "to": "fix" },
    { "from": "fix",    "to": "review" },
    { "from": "review", "to": "fix" }
  ]
}
