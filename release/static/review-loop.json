{
  "nodes": [
    {
      "id": "seed",
      "providers": [{ "type": "shell", "command": "scripts/node_ok.bat" }],
      "process_timeout_secs": 10
    },
    {
      "id": "review",
      "providers": [{
        "type": "llm",
        "command": "claude -p \"{{prompt}}\" --output-format json --verbose --dangerously-skip-permissions",
        "prompt": "Round {{metadata.run_count}}/2. Read ../bak/design/ARCHITECTURE.md. Critique abstraction consistency, design rationale, logical gaps. Last fix: {{inputs.fix}}. Issues → route='again'. Done → route='stop'. Output ONLY: {\"route\":\"again|stop\",\"content\":\"## Review\\n...\"}. Write review to review.md.",
        "routes": ["again", "stop"]
      }],
      "process_timeout_secs": 300,
      "route_policy": { "type": "max_runs", "max": 2, "then_route": "stop" }
    },
    {
      "id": "fix",
      "providers": [{
        "type": "llm",
        "command": "claude -p \"{{prompt}}\" --output-format json --verbose --dangerously-skip-permissions",
        "prompt": "Read ../bak/design/ARCHITECTURE.md. Rewrite problematic sections based on review: {{inputs.review}}. Output ONLY: {\"route\":\"done\",\"content\":\"## Fix\\n...\"}. Write fixes to fix.md.",
        "routes": ["done"]
      }],
      "process_timeout_secs": 300
    },
    {
      "id": "exit",
      "providers": [{ "type": "shell", "command": "scripts/node_ok.bat" }],
      "process_timeout_secs": 10
    }
  ],
  "edges": [
    { "from": "seed",   "to": "review", "trigger": "any", "event": "complete" },
    { "from": "review", "to": "fix",    "trigger": "any", "event": "complete", "exit_reason": "again" },
    { "from": "fix",    "to": "review", "trigger": "any", "event": "complete" },
    { "from": "review", "to": "exit",   "trigger": "any", "event": "complete", "exit_reason": "stop" }
  ],
  "dataflows": [
    { "from": "fix",    "to": "review" },
    { "from": "review", "to": "fix" }
  ]
}
